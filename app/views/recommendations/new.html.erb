<%= render 'shared/navbar' %>
<%= render 'shared/breadcrumbs' %>

<div class="container py-5">
  <h2 class="text-center mb-5 text-green font-lobster">
    Recommend Products for <%= @client.name %>
  </h2>

  <% products = [@shampoo, @conditioner].compact %>
  <% if products.any? %>
    <div class="row g-4">
      <% products.each do |product| %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card green-shadow h-100 p-3 border-blue" data-product-id="<%= product.id %>">
            <div class="card-body d-flex flex-column justify-content-between text-center">

              <h4 class="card-title text-blue mb-2"><%= product.name %></h4>
              <p class="card-text text-muted mb-3"><%= product.description %></p>

              <% recommendation = @client.recommendations.find_by(product_id: product.id) %>

              <% if recommendation %>
                <%= button_to "Unrecommend", client_recommendation_path(@client, recommendation), 
                              method: :delete, 
                              data: { confirm: "Remove this product from the Mane Vault?" }, 
                              class: "btn btn-danger w-100 mb-2" %>
              <% else %>
                <%= form_with model: Recommendation.new, url: client_recommendations_path(@client), local: true do |f| %>
                  <%= hidden_field_tag :redirect_to, request.fullpath %>

                  <%# NOTE: You could move this logic to a controller. It’s better to avoid hidden fields on the frontend unless absolutely necessary. %>
                  <%= f.hidden_field :product_id, value: product.id %>
                  <%= f.submit "Recommend", class: "btn btn-primary w-100" %>
                <% end %>
              <% end %>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted fs-5">No products available to recommend.</p>
  <% end %>
</div>

<%# NOTE: These CSS styles should be in the assets folder, not here. %>

<style>
  .text-green { color: #2e7d32; }
  .text-blue { color: #0d6efd; }
  .font-lobster { font-family: 'Lobster', cursive; }
  .green-shadow { box-shadow: 0 4px 6px rgba(46,125,50,0.3); border-radius: 0.5rem; }
  .border-blue { border: 1px solid #0d6efd; }
  .card-body { padding: 1.5rem; }
</style>
