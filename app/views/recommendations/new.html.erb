<%= render 'shared/navbar' %>
<h2 class="mb-4 text-center">Recommend Products for <%= @client.name %></h2>

<div class="row justify-content-center g-4">
  <% [@shampoo, @conditioner].each do |product| %>
    <% next unless product %>
    <div class="col-md-5 mb-4">
      <div class="card h-100 shadow-sm p-3">
        <div class="card-body text-center d-flex flex-column justify-content-between">

          <h4 class="card-title mb-2"><%= product.name %></h4>
          <p class="card-text mb-3"><%= product.description %></p>

          <% recommendation = @client.recommendations.find_by(product_id: product.id) %>

          <% if recommendation %>

            <%= button_to "Unrecommend", client_recommendation_path(@client, recommendation), 
                          method: :delete, 
                          data: { confirm: "Remove this product from the Mane Vault?" }, 
                          class: "btn btn-danger w-100 mb-3" %>

          <% else %>

            <%= form_with model: Recommendation.new, url: client_recommendations_path(@client), local: true do |f| %>
              <%= hidden_field_tag :redirect_to, request.fullpath %>
              <%= f.hidden_field :product_id, value: product.id %>

              <%= f.submit "Recommend", class: "btn btn-primary w-100" %>
            <% end %>
          <% end %>

        </div>
      </div>
    </div>
  <% end %>
</div>

<style>
  .text-purple { color: #6f42c1; }
  .card-body { padding: 1.5rem; }
  .row.g-4 > .col-md-5 { margin-bottom: 1.5rem; }
</style>
