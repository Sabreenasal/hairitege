<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
  <div class="container d-flex align-items-center">
    <span class="navbar-brand mb-0" style="font-family: 'Lobster', cursive; font-size: 1.8rem; color: #2e7d32;">
      Hairitege
    </span>

  </div>
</nav>

<div class="container d-flex justify-content-center align-items-center min-vh-100">
  <div class="card shadow-lg border-0" style="max-width: 500px; width: 100%; border-radius: 20px; overflow: hidden;">

    <div class="card-header text-center text-white py-4" 
         style="background: linear-gradient(135deg, #1b5e20 0%, #66bb6a 100%); font-family: 'Lora', serif;">
      <h2 class="mb-0 fw-bold">Sign Up</h2>
    </div>

    <div class="card-body p-4 p-lg-5" style="background: rgba(255, 255, 255, 0.95);">

      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.error_notification %>

        <div class="mb-3">
          <%= f.label :name, "Name", class: "form-label fw-semibold text-success" %>
          <%= f.input_field :name, class: "form-control", required: true, autofocus: true %>
        </div>

        <div class="mb-3">
          <%= f.label :email, "Email", class: "form-label fw-semibold text-success" %>
          <%= f.input_field :email, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :password, "Password", class: "form-label fw-semibold text-success" %>
          <%= f.input_field :password, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :password_confirmation, "Password Confirmation", class: "form-label fw-semibold text-success" %>
          <%= f.input_field :password_confirmation, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :role, "Role", class: "form-label fw-semibold text-success" %>
          <%= f.select :role, options_for_select([["Stylist", "stylist"], ["Client", "client"]]), { prompt: "Select your role" }, class: "form-select" %>
        </div>

        <div class="form-actions mt-4 text-center">
          <%= f.button :submit, "Sign Up", class: "btn btn-success btn-lg px-5 fw-bold shadow-sm" %>
        </div>

      <% end %>

      <div class="text-center mt-3">
        <%= render "devise/shared/links" %>
      </div>

    </div>
  </div>
</div>
